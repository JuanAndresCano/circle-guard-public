pipeline {
    agent any

    environment {
        APP_VERSION = "1.0.${BUILD_NUMBER}"
        GRADLE_USER_HOME = "/var/jenkins_home/.gradle"
        TESTCONTAINERS_RYUK_DISABLED = "true"
        DOCKER_HOST = "unix:///var/run/docker.sock"
        TESTCONTAINERS_HOST_OVERRIDE = "host.docker.internal"
        CI = "true"
        DOCKER_REGISTRY = 'localhost:5000'
        NAMESPACE = 'dev'
        IMAGE_TAG = "${env.BUILD_NUMBER}"
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
                sh 'chmod +x gradlew'
            }
        }

        stage('Build') {
            steps {
                sh './gradlew build -x test --no-daemon'
            }
        }

        stage('Docker Build') {
            steps {
                script {
                    def services = [
                        'circleguard-gateway-service',
                        'circleguard-auth-service',
                        'circleguard-promotion-service'
                    ]

                    services.each { service ->
                        def imageName = "${env.DOCKER_REGISTRY}/${service}:${env.IMAGE_TAG}"
                        def imageLatest = "${env.DOCKER_REGISTRY}/${service}:latest"

                        echo "Building: ${imageName}"
                        sh """
                            docker build \
                                -t ${imageName} \
                                -t ${imageLatest} \
                                -f services/${service}/Dockerfile \
                                .
                        """
                    }

                    echo "✅ 3 core images built successfully"
                }
            }
        }

        stage('Deploy Infrastructure') {
            steps {
                sh 'docker compose -f docker-compose.dev.yml down --remove-orphans --timeout 30 || true'
                sh 'docker compose -f docker-compose.dev.yml up -d'
                sh 'sleep 35'
                sh 'echo "✅ Infrastructure ready"'
            }
        }

        stage('Unit Tests') {
            steps {
                sh './gradlew test -x :services:circleguard-gateway-service:test --no-daemon --continue'
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: '**/build/test-results/test/TEST-*.xml'
                }
            }
        }

        stage('Integration Tests') {
            steps {
                sh '''
                    ./gradlew :services:circleguard-auth-service:integrationTest \
                        --no-daemon --continue
                '''
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: '**/build/test-results/integrationTest/TEST-*.xml'
                }
            }
        }

        stage('E2E Tests') {
            steps {
                sh '''
                    ./gradlew :services:circleguard-auth-service:e2eTest \
                        --no-daemon --continue
                '''
            }
            post {
                always {
                    junit allowEmptyResults: true, testResults: '**/build/test-results/e2eTest/TEST-*.xml'
                }
            }
        }

        stage('Performance Tests') {
            steps {
                sh '''
                    docker rm -f locust-runner || true

                    docker create --name locust-runner --network host locustio/locust:latest \
                        -f /home/locust/locustfile.py \
                        --headless \
                        --users 20 \
                        --spawn-rate 5 \
                        --run-time 30s \
                        --host http://localhost:8180 \
                        --csv /home/locust/results \
                        --html /home/locust/report.html

                    docker cp performance/locustfile.py locust-runner:/home/locust/locustfile.py
                    docker start -a locust-runner || true

                    docker cp locust-runner:/home/locust/report.html performance/report.html || true
                    docker cp locust-runner:/home/locust/results_stats.csv performance/results_stats.csv || true
                    docker cp locust-runner:/home/locust/results_failures.csv performance/results_failures.csv || true
                    docker cp locust-runner:/home/locust/results_exceptions.csv performance/results_exceptions.csv || true
                    docker cp locust-runner:/home/locust/results_stats_history.csv performance/results_stats_history.csv || true

                    docker rm -f locust-runner || true
                '''
            }
            post {
                always {
                    archiveArtifacts artifacts: 'performance/report.html,performance/results_*.csv',
                                     allowEmptyArchive: true
                }
            }
        }
    }

    post {
        always {
            echo "Pipeline finalizado — build #${BUILD_NUMBER}"
        }
        failure {
            echo "Pipeline FALLIDO — verifique los logs"
        }
        success {
            echo "Pipeline EXITOSO — versión ${APP_VERSION} desplegada"
        }
    }
}
pipeline {
    agent any

    environment {
        APP_VERSION = "1.0.${BUILD_NUMBER}"
        GRADLE_USER_HOME = "/var/jenkins_home/.gradle"
        TESTCONTAINERS_RYUK_DISABLED = "true"
        DOCKER_HOST = "unix:///var/run/docker.sock"
        CI = "true"
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh './gradlew build -x test --no-daemon'
            }
        }

        // ── UNIT TESTS ─────────────────────────────────────────────────
        // Rápidos, sin Docker ni BD. Corren siempre.
        stage('Unit Tests') {
            steps {
                sh './gradlew test --no-daemon'
                // El build.gradle.kts excluye tags e2e e integration del task "test"
                // así que solo corren los unit tests aquí
            }
            post {
                always {
                    junit '**/build/test-results/test/TEST-*.xml'
                }
            }
        }

        // ── DIAGNÓSTICO DOCKER ─────────────────────────────────────────
        stage('Docker Diagnostics') {
            steps {
                sh '''
                    echo "=== Docker version ==="
                    docker version || true
                    echo "=== Socket ==="
                    ls -l /var/run/docker.sock || true
                    echo "=== Env ==="
                    env | grep -E 'DOCKER|TESTCONTAINERS|CI' | sort || true
                '''
            }
        }

        // ── INTEGRATION TESTS ──────────────────────────────────────────
        // Usan Testcontainers (PostgreSQL) + WireMock
        stage('Integration Tests') {
            environment {
                TESTCONTAINERS_HOST_OVERRIDE = 'host.docker.internal'
            }
            steps {
                sh './gradlew :services:circleguard-auth-service:integrationTest --no-daemon --rerun-tasks'
            }
            post {
                always { junit '**/build/test-results/test/TEST-*.xml' }
            }
        }

        // ── E2E TESTS ──────────────────────────────────────────────────
        // Flujos completos de usuario con Testcontainers + WireMock
        stage('E2E Tests') {
            environment {
                TESTCONTAINERS_HOST_OVERRIDE = 'host.docker.internal'
            }
            steps {
                sh './gradlew :services:circleguard-auth-service:e2eTest --no-daemon --rerun-tasks'
            }
            post {
                always {
                    junit '**/build/test-results/test/TEST-*.xml'
                }
            }
        }

        // ── DEPLOY DEV ────────────────────────────────────────────────
        stage('Deploy Dev') {
            steps {
                // Limpieza forzada por si quedaron contenedores huérfanos de otros builds o pruebas
                sh 'docker rm -f circleguard-neo4j circleguard-postgres circleguard-redis circleguard-zookeeper circleguard-ldap circleguard-kafka || true'
                
                // En el Jenkinsfile, stage de deploy:
                sh 'docker compose -f docker-compose.dev.yml down --remove-orphans'
                sh 'docker compose -f docker-compose.dev.yml up -d --build'
            }
        }

        // ── PERFORMANCE TESTS ─────────────────────────────────────────
        // Locust en Docker contra el servicio levantado
        stage('Performance Tests') {
            steps {
                sh """
                    # 1. Limpiar contenedor previo si existe
                    docker rm -f locust-runner || true
                    
                    # 2. Crear el contenedor sin arrancarlo
                    docker create --name locust-runner --network host locustio/locust:latest \
                        -f /home/locust/locustfile.py \
                        --headless \
                        --users 20 \
                        --spawn-rate 5 \
                        --run-time 30s \
                        --host http://localhost:8180 \
                        --csv /home/locust/results \
                        --html /home/locust/report.html
                    
                    # 3. Copiar el script de pruebas de Jenkins al contenedor
                    docker cp performance/locustfile.py locust-runner:/home/locust/locustfile.py
                    
                    # 4. Arrancar el contenedor y atar la salida (-a)
                    docker start -a locust-runner || true
                    
                    # 5. Extraer los resultados de vuelta al workspace de Jenkins 
                    docker cp locust-runner:/home/locust/report.html performance/report.html || true
                    docker cp locust-runner:/home/locust/results_stats.csv performance/results_stats.csv || true
                    docker cp locust-runner:/home/locust/results_failures.csv performance/results_failures.csv || true
                    docker cp locust-runner:/home/locust/results_exceptions.csv performance/results_exceptions.csv || true
                    docker cp locust-runner:/home/locust/results_history.csv performance/results_history.csv || true
                    
                    # 6. Limpieza final
                    docker rm -f locust-runner || true
                """
            }
            post {
                always {
                    archiveArtifacts artifacts: 'performance/report.html,performance/results_*.csv',
                                     allowEmptyArchive: true
                }
            }
        }
    }

    post {
        always {
            echo "Pipeline finalizado — build #${BUILD_NUMBER}"
        }
        failure {
            echo "Pipeline FALLIDO en stage: verifique los logs"
        }
        success {
            echo "Pipeline EXITOSO — versión ${APP_VERSION} desplegada"
        }
    }
}
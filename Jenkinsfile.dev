pipeline {
    agent any

    environment {
        APP_VERSION = "1.0.${BUILD_NUMBER}"
        GRADLE_USER_HOME = "/var/jenkins_home/.gradle"
        SERVICES = "circleguard-auth-service circleguard-identity-service circleguard-gateway-service circleguard-form-service circleguard-promotion-service circleguard-notification-service"
        TESTCONTAINERS_RYUK_DISABLED = "true"
        DOCKER_HOST = "unix:///var/run/docker.sock"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Build') {
            steps {
                sh './gradlew build -x test --no-daemon'
            }
        }

        stage('Testcontainers Diagnostics') {
            steps {
                sh '''
                    echo "=== Docker ==="
                    docker version || true
                    docker ps -a || true
                    ls -l /var/run/docker.sock || true

                    echo "=== Env ==="
                    env | grep -E 'DOCKER|TESTCONTAINERS|CI' | sort || true
                '''
            }
        }

        stage('Integration Tests') {
            environment {
                TESTCONTAINERS_HOST_OVERRIDE = 'host.docker.internal'
            }
            steps {
                sh './gradlew :services:circleguard-auth-service:test --no-daemon --stacktrace --info --tests "com.circleguard.auth.integration.LoginIntegrationTest"'
            }
            post {
                always {
                    junit '**/build/test-results/test/TEST-*.xml'
                }
            }
        }
    }
}